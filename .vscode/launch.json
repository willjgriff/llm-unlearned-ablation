{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "modelKey",
      "type": "pickString",
      "description": "Model key from config/models.yaml",
      "options": [
        "baseline_full",
        "npo_unlearned_lr1e-05_beta0.5_alpha5_epoch5",
        "npo_unlearned_lr2e-05_beta0.5_alpha5_epoch5",
        "npo_unlearned_lr2e-05_beta0.5_alpha1_epoch10",
        "npo_unlearned_lr5e-05_beta0.5_alpha1_epoch10",
        "ga_unlearned_lr4e-05_alpha10_epoch10",
        "idk_nll_unlearned_lr2e-05_alpha10_epoch5",
        "idk_nll_unlearned_lr3e-05_alpha10_epoch5",
        "idk_nll_unlearned_lr4e-05_alpha5_epoch5"
      ],
      "default": "baseline_full"
    },
    {
      "id": "directionsSource",
      "type": "pickString",
      "description": "Direction source for ablation",
      "options": [
        "refusal",
        "confabulation"
      ],
      "default": "refusal"
    }
  ],
  "configurations": [
    {
      "name": "tofu_probe",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/tofu_probe.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "--model-key",
        "${input:modelKey}",
        "--num-questions",
        "400"
      ]
    },
    {
      "name": "refusal_direction",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/refusal_direction.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "--model-key",
        "${input:modelKey}",
        "--num-questions",
        "400"
      ]
    },
    {
      "name": "confabulation_direction",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/confabulation_direction.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "--model-key",
        "${input:modelKey}",
        "--num-questions",
        "400"
      ]
    },
    {
      "name": "probe_direction",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/probe_direction.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "--model-key",
        "${input:modelKey}",
        "--num-questions",
        "400"
      ]
    },
    {
      "name": "ablate_and_probe",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/ablate_and_probe.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "--model-key",
        "${input:modelKey}",
        "--num-questions",
        "400",
        "--ablation-method",
        "steer",
        "--steering-layer",
        "14",
        "--steering-coefficients",
        "1.5",
        "--directions-source",
        "refusal",
        "--repetition-penalty",
        "1.1"
      ]
    }
  ]
}
