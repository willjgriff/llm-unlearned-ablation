{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "modelKey",
      "type": "pickString",
      "description": "Model key from config/models.yaml",
      "options": [
        "baseline_full",
        "npo_unlearned",
        "ga_unlearned",
        "idk_nll_unlearned_lr3e-05_alpha10_epoch5",
        "idk_nll_unlearned_lr4e-05_alpha5_epoch5"
      ],
      "default": "npo_unlearned"
    }
  ],
  "configurations": [
    {
      "name": "tofu_probe",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/tofu_probe.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "--model-key",
        "${input:modelKey}",
        "--num-questions",
        "20"
      ]
    },
    {
      "name": "refusal_direction",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/refusal_direction.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "--model-key",
        "${input:modelKey}",
        "--num-questions",
        "400"
      ]
    },
    {
      "name": "ablate_and_probe",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/ablate_and_probe.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "--model-key",
        "${input:modelKey}",
        "--num-questions",
        "20",
        "--ablation-method",
        "hooks"
      ]
    }
  ]
}
